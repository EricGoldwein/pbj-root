# Copy to .env and fill in values. .env is gitignored; never commit real passwords.
# Used for: CSRF (SECRET_KEY), optional subscribe notification email (SUBSCRIBE_NOTIFY_*).

# --- Subscribe notification email (optional) ---
# Notifications are sent only when SUBSCRIBE_NOTIFY_SMTP_HOST is set.
# Who receives the "New subscriber" email (comma-separated):
SUBSCRIBE_NOTIFY_TO=egoldwein@gmail.com,eric@320insight.com

# SMTP server (required for notifications to be sent)
SUBSCRIBE_NOTIFY_SMTP_HOST=smtp.gmail.com
SUBSCRIBE_NOTIFY_SMTP_PORT=587

# Gmail: use an App Password, not your normal password.
# Create at: Google Account → Security → 2-Step Verification → App passwords.
SUBSCRIBE_NOTIFY_SMTP_USER=your.email@gmail.com
SUBSCRIBE_NOTIFY_SMTP_PASSWORD=your-app-password-here

# Optional: "From" address (defaults to SMTP user or noreply@pbj320.com)
# SUBSCRIBE_NOTIFY_FROM=noreply@pbj320.com
